# =============================================================================
# Project root `.env` — loaded first; `server/.env` overrides if both exist.
# =============================================================================
# For a minimal start, copy this file to `.env` and adjust MongoDB if needed.

# MongoDB (Mongoose)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=wedding_website

# API + static + Vite (dev) all listen on PORT
PORT=5000
NODE_ENV=development

# Session cookies (set in dev too if you switch machines often)
SESSION_SECRET=dev-change-me

# Optional: bind address (default 0.0.0.0)
# LISTEN_HOST=0.0.0.0

# --- Client (Vite) — only if you use a separate `vite` dev server ---
# See `client/.env.example`. Usually leave unset and use `npm run dev`.
# VITE_API_BASE_URL=http://127.0.0.1:5000

# Optional: MongoDB Atlas connection string format
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/wedding_website?retryWrites=true&w=majority

# --- Cloudinary (images / uploads) ---
# Option A (recommended): one URL from the Cloudinary dashboard → API Environment variable
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
#
# Option B: three values (same as in the dashboard)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=xxxxxxxx
# CLOUDINARY_API_SECRET=xxxxxxxx

#
# Optional: default folder for uploads (you can still pass a path per upload in code)
# CLOUDINARY_FOLDER=weddings
#
# Optional: unsigned upload preset name (only if you use direct browser uploads with that preset)
# CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
#
# Client (Vite): only non-secret values — never put API_SECRET in VITE_*
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
