# =============================================================================
# Server / database — copy to `server/.env` or set in project root `.env`
# =============================================================================
# Both `./.env` and `./server/.env` are loaded (server/.env overrides root).

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=wedding_website

PORT=5000
NODE_ENV=development

# Required in production — use a long random string (openssl rand -hex 32)
SESSION_SECRET=change-me-in-production

# Optional: bind address (default 0.0.0.0)
# LISTEN_HOST=0.0.0.0

# --- Cloudinary (if you use uploads) ---
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
