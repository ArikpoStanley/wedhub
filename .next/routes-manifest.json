{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/contacts/search/[query]",
      "regex": "^/api/contacts/search/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPquery": "nxtPquery"
      },
      "namedRegex": "^/api/contacts/search/(?<nxtPquery>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/contacts/[id]",
      "regex": "^/api/contacts/([^/]+?)(?:/)?$",
