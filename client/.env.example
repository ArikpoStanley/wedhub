# =============================================================================
# Client (Vite) — optional
# =============================================================================
# Recommended: run the full stack with `npm run dev` from the repo root.
# Then you do NOT need this file: the browser and API share the same origin.

# --- Only if the UI is NOT served from the same host/port as the API ---
# Example: `vite` on http://localhost:5173 and Express on http://127.0.0.1:5000
# Uncomment and point at your backend (no trailing slash):
# VITE_API_BASE_URL=http://127.0.0.1:5000

# --- Only when using `vite` dev server + proxy (see vite.config.ts) ---
# If your API runs on a different port, set this before starting Vite (defaults to 5000):
# VITE_PROXY_API=http://127.0.0.1:5000

# --- Public values only (never put secrets in VITE_*) ---
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
